{
	"name": "blog-api",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"db:migrate": "prisma migrate dev",
		"db:seed": "prisma db seed",
		"db:studio": "prisma studio",
		"db:reset": "prisma migrate reset",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.13",
		"@hono/oauth-providers": "^0.8.5",
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.4.1",
		"hono": "^4.12.12",
		"jsonwebtoken": "^9.0.3",
		"pg": "^8.20.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^20.11.17",
		"@types/pg": "^8.20.0",
		"@vitest/coverage-v8": "^4.1.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.59.0",
		"prisma": "^7.6.0",
		"tsx": "^4.7.1",
		"typescript": "^5.8.3",
		"vitest": "^4.1.2"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"oxlint --fix",
			"oxfmt"
		],
		"*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
			"oxfmt"
		]
	}
}
